datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String    @unique
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  roleId        String    @db.ObjectId
  role          Role      @relation(fields: [roleId], references: [id])
  status        String    @default("ACTIVE") // ACTIVE, INACTIVE, BLOCKED
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  mustChangePassword Boolean   @default(false)
  collegeName        String?
  collegeIdCard      String?
  otpCode            String?
  otpExpiry          DateTime?

  // Module Relationships
  blogs               BlogPost[]
  auditLogs           AuditLog[]
  managedProjects     Project[]         @relation("ProjectManager")
  developedProjects   Project[]         @relation("ProjectDevelopers", fields: [developedProjectIds], references: [id])
  developedProjectIds String[]          @db.ObjectId
  designedProjects    Project[]         @relation("ProjectDesigners", fields: [designedProjectIds], references: [id])
  designedProjectIds  String[]          @db.ObjectId
  assignedTasks       Task[]
  assignedMeetings    Meeting[]
  assignedTickets     SupportTicket[]
  clientProfile       Client?
}

model Role {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  name        String            @unique // SUPER_ADMIN, ADMIN, EMPLOYEE, CLIENT, custom
  description String?
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  name        String            @unique // e.g. "view_projects", "create_invoices"
  description String?
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  roleId       String     @db.ObjectId
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String     @db.ObjectId
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

// CRM Module
model Lead {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  companyName  String?
  email        String
  phone        String?
  whatsapp     String?
  country      String?
  service      String?
  budget       String?
  timeline     String?
  source       String    @default("WEBSITE")
  priority     String    @default("LOW") // LOW, MEDIUM, HIGH, URGENT
  status       String    @default("NEW") // NEW, CONTACTED, QUALIFIED, PROPOSAL_SENT, NEGOTIATION, WON, LOST, ARCHIVED
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Client Portal & Document Module
model Client {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  companyName String
  ownerName   String
  email       String   @unique
  phone       String?
  address     String?
  gst         String?
  country     String?
  userId      String?  @unique @db.ObjectId
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  projects    Project[]
  quotations  Quotation[]
  agreements  Agreement[]
  invoices    Invoice[]
  tickets     SupportTicket[]
}

// Project Domain
model Project {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  slug         String?   @unique
  clientId     String    @db.ObjectId
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  managerId    String?   @db.ObjectId
  manager      User?     @relation("ProjectManager", fields: [managerId], references: [id])
  developers   User[]    @relation("ProjectDevelopers", fields: [developerIds], references: [id])
  developerIds String[]  @db.ObjectId
  designers    User[]    @relation("ProjectDesigners", fields: [designerIds], references: [id])
  designerIds  String[]  @db.ObjectId
  startDate    DateTime?
  deadline     DateTime?
  status       String    @default("PLANNING") // PLANNING, DESIGN, DEVELOPMENT, TESTING, DEPLOYMENT, COMPLETED, MAINTENANCE
  progress     Int       @default(0)
  budget       Float?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  milestones   Milestone[]
  tasks        Task[]
  invoices     Invoice[]
  expenses     Expense[]
}

model Milestone {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String   @db.ObjectId
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
}

model Task {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  projectId    String    @db.ObjectId
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  assignedToId String?   @db.ObjectId
  assignedTo   User?     @relation(fields: [assignedToId], references: [id])
  dueDate      DateTime?
  priority     String    @default("LOW") // LOW, MEDIUM, HIGH
  status       String    @default("TODO") // TODO, IN_PROGRESS, REVIEW, DONE
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Invoices & Billing
model Invoice {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  invoiceNumber String    @unique
  clientId      String    @db.ObjectId
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId     String?   @db.ObjectId
  project       Project?  @relation(fields: [projectId], references: [id])
  date          DateTime
  dueDate       DateTime
  items         Json      // Line items [{ description, quantity, price, tax }]
  subtotal      Float
  discount      Float     @default(0)
  tax           Float     @default(0)
  grandTotal    Float
  status        String    @default("UNPAID") // UNPAID, PAID, OVERDUE, CANCELLED
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Agreements Engine
model Agreement {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  agreementNumber String    @unique
  clientId        String    @db.ObjectId
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title           String
  content         String
  status          String    @default("DRAFT") // DRAFT, SENT, SIGNED
  clientSignature String?
  signedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Product CMS
model Product {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  slug             String    @unique
  category         String
  description      String
  version          String?
  status           String    @default("LIVE") // COMING_SOON, LIVE, ARCHIVED
  demoUrl          String?
  liveUrl          String?
  logoUrl          String?
  features         Json      // Array of features
  pricingPlans     Json      // Dynamic tiers
  changelog        Json?     // Array of version logs
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// Blog
model BlogPost {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  slug          String    @unique
  content       String
  featuredImage String?
  authorId      String    @db.ObjectId
  author        User      @relation(fields: [authorId], references: [id])
  category      String
  tags          String[]
  status        String    @default("DRAFT") // DRAFT, PUBLISHED
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Portfolio
model PortfolioProject {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  slug         String   @unique
  description  String
  category     String
  technologies String[]
  liveUrl      String?
  coverUrl     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Website Builder & Section Configuration
model Page {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  slug            String    @unique
  metaTitle       String?
  metaDescription String?
  status          String    @default("DRAFT")
  sections        Section[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Section {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  pageId    String   @db.ObjectId
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      String
  order     Int
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Meetings Planner
model Meeting {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  email              String
  meetingType        String
  preferredDate      DateTime
  preferredTime      String
  timezone           String
  details            String?
  status             String    @default("PENDING") // PENDING, CONFIRMED, COMPLETED
  assignedEmployeeId String?   @db.ObjectId
  assignedEmployee   User?     @relation(fields: [assignedEmployeeId], references: [id])
  createdAt          DateTime  @default(now())
}

// Support Ticketing
model SupportTicket {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  clientId           String   @db.ObjectId
  client             Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subject            String
  category           String
  priority           String   @default("LOW") // LOW, MEDIUM, HIGH, CRITICAL
  status             String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  assignedEmployeeId String?  @db.ObjectId
  assignedEmployee   User?    @relation(fields: [assignedEmployeeId], references: [id])
  createdAt          DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())
}

model Quotation {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  quotationNumber String    @unique
  clientId        String    @db.ObjectId
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date            DateTime
  expiryDate      DateTime
  items           Json      // Array of items [{ description, quantity, price, discount, tax }]
  subtotal        Float
  discount        Float     @default(0)
  tax             Float     @default(0)
  grandTotal      Float
  status          String    @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED, CONVERTED
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model JobPosition {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  department  String
  location    String
  type        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StudentProjectRequest {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  studentName  String
  studentEmail String
  collegeName  String
  projectTitle String
  description  String
  status       String   @default("PENDING") // PENDING, APPROVED, IN_PROGRESS, COMPLETED
  createdAt    DateTime @default(now())
}

model Expense {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String   @db.ObjectId
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  amount      Float
  category    String   // e.g. "HOSTING", "DOMAIN", "DEVELOPER_PAYOUT", "MARKETING", "OTHER"
  description String
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

